# Telegram Bot Credentials
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
BOT_USERNAME=mysmart_v2_2026_bot

# AI Provider Configuration (openai | gemini)
AI_PROVIDER=gemini
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# Database Connection (MySQL)
DATABASE_URL=mysql://root:password@127.0.0.1:3306/smart_ai_assistant

# Application Server & Web Configuration
APP_URL=http://localhost:3000
PORT=3000

# Webhook Configuration (Production)
WEBHOOK_DOMAIN=https://yourdomain.com
WEBHOOK_SECRET=your_secret_webhook_token

# Storage and Files
MAX_IMAGE_SIZE_MB=10
TEMP_DIRECTORY=./temp
STORAGE_DRIVER=local
STORAGE_PUBLIC_URL=http://localhost:3000/public

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info
