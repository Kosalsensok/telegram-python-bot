# Smart AI Assistant Telegram Bot Environment Variables

# Telegram Bot Credentials (REQUIRED)
BOT_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_DISPLAY_NAME=Smart AI Assistant

# Gemini AI API Configuration (REQUIRED)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-3.6-flash

# Application Logging Level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# MySQL Database Configurations
USE_DATABASE=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=smart_ai_assistant

# Deployment & Web Server
PORT=8080
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# User Tracking & Profile Auto-Updater
SHOW_USER_COUNT_IN_BOT_NAME=true
PROFILE_UPDATE_INTERVAL_MINUTES=5
MAX_HISTORY_MESSAGES=20
MAX_IMAGE_SIZE_MB=10

# Admin Access Control (Comma-separated Telegram User IDs)
ADMIN_USER_IDS=123456789,987654321
STATS_PUBLIC=true
